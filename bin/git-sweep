#!/usr/bin/env bash
#
# git-sweep — delete local branches already merged into the base branch.
#
# Fetches first and compares against the base's REMOTE tip (origin/<base>), so it
# works without pulling the base locally and from any branch you're on — a branch
# merged upstream is swept even if your local main is stale.
#
# Safe by default: uses `git branch -d`, which refuses any branch that isn't
# fully merged (never -D). Note: squash-merged branches are NOT caught — a
# squash makes a brand-new commit, so the branch isn't an ancestor of the base.
#
# --force widens the net: it targets EVERY local branch (except the base and the
# current one) and force-deletes with `git branch -D` — so it also clears
# branches that were never PR'd/merged and squash-merged leftovers. This DELETES
# UNMERGED WORK; use `-n` first to see exactly what it would remove.
#
# Usage:
#   git sweep            delete local branches merged into the base (safe, -d)
#   git sweep -f         force: -D every local branch except base + current
#   git sweep -n         dry run — list what would be deleted, change nothing
#   git sweep -b NAME    base branch to compare against (default: origin's default)
#   git sweep -h         show this help
#
set -euo pipefail

usage() {
  cat <<'EOF'
git sweep — delete local branches already merged into the base branch.

Safe by default: uses `git branch -d`, which refuses anything not fully merged
(never -D). Squash-merged branches are NOT caught (a squash isn't an ancestor).

--force targets EVERY local branch except the base and current one and deletes
with `git branch -D` — clearing never-PR'd / squash-merged / unmerged branches
too. This deletes unmerged work; run with -n first.

Usage:
  git sweep          delete local branches merged into the base (safe, -d)
  git sweep -f       force: -D every local branch except base + current
  git sweep -n       dry run — list what would be deleted, change nothing
  git sweep -b NAME  base branch to compare against (default: origin's default)
  git sweep -h       show this help

  -f and -n combine: `git sweep -f -n` previews the force sweep.
EOF
}

dry=0
force=0
base=""
while [ $# -gt 0 ]; do
  case "$1" in
    -n|--dry-run) dry=1 ;;
    -f|--force) force=1 ;;
    -b|--base) shift; base="${1:-}" ;;
    -h|--help) usage; exit 0 ;;
    *) echo "git sweep: unknown option '$1' (try -h)" >&2; exit 2 ;;
  esac
  shift
done

git rev-parse --is-inside-work-tree >/dev/null 2>&1 || {
  echo "git sweep: not inside a git repository" >&2; exit 1; }

# Refresh remote-tracking refs first (best effort; ignore offline failures) so
# "merged" is judged against origin's current tip. This is what lets sweep work
# WITHOUT first pulling the base locally, and from any branch you're on.
git fetch --prune --quiet 2>/dev/null || true

# Choose a base branch NAME if none given: origin's default (origin/HEAD), else
# main/master (local or on origin), else the current branch.
if [ -z "$base" ]; then
  base=$(git symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null \
    | sed 's#^origin/##' || true)
  if [ -z "$base" ]; then
    for b in main master; do
      if git show-ref --verify --quiet "refs/heads/$b" \
         || git show-ref --verify --quiet "refs/remotes/origin/$b"; then
        base=$b; break
      fi
    done
  fi
  [ -n "$base" ] || base=$(git rev-parse --abbrev-ref HEAD)
fi

# Judge "merged" against the remote-tracking tip (origin/<base>) when it exists:
# the fetch above just updated it, so a branch merged upstream is detected even
# when your local <base> is stale (no `git pull` needed) and no matter which
# branch you're on. Fall back to the local branch when offline / no remote.
if git show-ref --verify --quiet "refs/remotes/origin/$base"; then
  mergeref="origin/$base"
elif git show-ref --verify --quiet "refs/heads/$base"; then
  mergeref="$base"
else
  echo "git sweep: base '$base' not found locally or on origin" >&2; exit 1
fi

current=$(git rev-parse --abbrev-ref HEAD)

# Candidate branches: with --force, every local branch; otherwise only those
# merged into the base tip. Either way we exclude the base and the current branch.
if [ "$force" = 1 ]; then
  list=$(git branch --format='%(refname:short)')
else
  list=$(git branch --merged "$mergeref" --format='%(refname:short)')
fi

targets=""
while IFS= read -r b; do
  [ -z "$b" ] && continue
  [ "$b" = "$base" ] && continue
  [ "$b" = "$current" ] && continue
  targets="$targets $b"
done <<EOF
$list
EOF
targets=$(echo $targets)  # trim whitespace

if [ -z "$targets" ]; then
  if [ "$force" = 1 ]; then
    echo "git sweep: no other local branches to delete."
  else
    echo "git sweep: nothing merged into '$base' to delete."
  fi
  exit 0
fi

if [ "$dry" = 1 ]; then
  if [ "$force" = 1 ]; then
    except="'$base'"
    [ "$current" != "$base" ] && except="$except and '$current'"
    echo "Would FORCE-delete (every local branch except $except):"
  else
    echo "Would delete (merged into '$base'):"
  fi
  for b in $targets; do echo "  $b"; done
  exit 0
fi

flag="-d"
[ "$force" = 1 ] && flag="-D"
for b in $targets; do git branch "$flag" "$b"; done
