#!/usr/bin/env bash
#
# git-done — switch back to the base branch and delete the branch you left.
#
# The bookend to `git pr`: after you've checked out a PR's branch and finished
# reviewing it, `git done` returns you to the base (origin's default, usually
# main), fast-forwards it to the latest on origin, and deletes the branch you
# were on.
#
# Safe by default: uses `git branch -d`, which refuses any branch that isn't
# fully merged — so hopping back to main can't silently drop working code. The
# catch is squash-merged PR branches: a squash isn't an ancestor of the base, so
# -d won't see them as merged and will refuse them too. When you know the branch
# is done, pass --force (`git branch -D`) to delete it regardless.
#
# On a detached HEAD there's nothing to delete, so it just switches back to base.
#
# Usage:
#   git done            switch to the base branch, delete the branch you left (-d)
#   git done -f         force-delete with -D (unmerged / squash-merged branches)
#   git done -b NAME    switch to NAME as the base instead of origin's default
#   git done -n         dry run — print what it would do, change nothing
#   git done -h         show this help
#
set -euo pipefail

# Colorized step output on a terminal (respects NO_COLOR). Each phase — switch,
# fast-forward, delete — prints one clear line instead of git's raw chatter.
if [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
  _ok=$'\033[32m'; _warn=$'\033[33m'; _dim=$'\033[2m'; _off=$'\033[0m'
else
  _ok=''; _warn=''; _dim=''; _off=''
fi
step() { printf '%s✓%s %s\n' "$_ok" "$_off" "$1"; }
warn() { printf '%s!%s %s\n' "$_warn" "$_off" "$1" >&2; }

usage() {
  cat <<'EOF'
git done — switch back to the base branch and delete the branch you left.

The bookend to `git pr`: after reviewing a checked-out PR branch, return to the
base (origin's default, usually main), fast-forward it to origin, and delete the
branch you were on.

Safe by default: `git branch -d` refuses anything not fully merged, so hopping
back to main can't silently drop working code. Squash-merged branches look
unmerged to -d and are refused too — use --force (`git branch -D`) for those.

Usage:
  git done          switch to the base branch, delete the branch you left (-d)
  git done -f       force-delete with -D (unmerged / squash-merged branches)
  git done -b NAME  use NAME as the base instead of origin's default
  git done -n       dry run — print what it would do, change nothing
  git done -h       show this help
EOF
}

dry=0
force=0
base=""
while [ $# -gt 0 ]; do
  case "$1" in
    -n|--dry-run) dry=1 ;;
    -f|--force) force=1 ;;
    -b|--base) shift; base="${1:-}" ;;
    -h|--help) usage; exit 0 ;;
    *) echo "git done: unknown option '$1' (try -h)" >&2; exit 2 ;;
  esac
  shift
done

git rev-parse --is-inside-work-tree >/dev/null 2>&1 || {
  echo "git done: not inside a git repository" >&2; exit 1; }

# On a detached HEAD there's no branch to delete — we still switch back to base,
# just skip the deletion at the end.
detached=0
current=$(git rev-parse --abbrev-ref HEAD)
[ "$current" != "HEAD" ] || detached=1

# Base = origin's default branch unless told otherwise (matches git sync/sweep).
if [ -z "$base" ]; then
  base=$(git symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null \
    | sed 's#^origin/##' || true)
  [ -n "$base" ] || base=main
fi

[ "$current" != "$base" ] || {
  echo "git done: you're already on '$base' — nothing to delete" >&2; exit 1; }

git show-ref --verify --quiet "refs/heads/$base" \
  || git show-ref --verify --quiet "refs/remotes/origin/$base" || {
  echo "git done: base '$base' not found locally or on origin" >&2; exit 1; }

flag="-d"
[ "$force" = 1 ] && flag="-D"

if [ "$dry" = 1 ]; then
  echo "Would run:"
  echo "  git switch $base"
  echo "  git fetch origin --prune  &&  git merge --ff-only origin/$base"
  if [ "$detached" = 1 ]; then
    echo "  (detached HEAD — no branch to delete)"
  else
    echo "  git branch $flag $current"
  fi
  exit 0
fi

# --- 1) switch to base (quietly; we narrate it ourselves) ---
git switch --quiet "$base"
step "switched to $base"

# --- 2) fast-forward base to origin so you land on current main. Best effort:
# fast-forward only (never a merge commit); note it if offline or diverged.
if git show-ref --verify --quiet "refs/remotes/origin/$base"; then
  git fetch --quiet origin --prune 2>/dev/null || true
  behind=$(git rev-list --count "$base..origin/$base" 2>/dev/null || echo 0)
  if [ "$behind" -gt 0 ]; then
    if [ "$behind" = 1 ]; then noun=commit; else noun=commits; fi
    if git merge --ff-only "origin/$base" >/dev/null 2>&1; then
      step "fast-forwarded $base to origin/$base ${_dim}(+$behind $noun)${_off}"
    else
      warn "couldn't fast-forward $base (diverged or offline) — left as is"
    fi
  else
    step "$base already up to date with origin/$base"
  fi
fi

if [ "$detached" = 1 ]; then
  step "was on a detached HEAD — nothing to delete"
  exit 0
fi

# --- 3) delete the branch you left. Suppress git's verbose -d warning (it's
# noisy about "merged upstream but not to HEAD") and print one clear line. Safe
# -d refuses unmerged (incl. squash-merged) branches — catch that and point at
# --force rather than letting set -e abort on a bare git error.
sha=$(git rev-parse --short "$current" 2>/dev/null || echo '?')
if git branch "$flag" "$current" >/dev/null 2>&1; then
  step "deleted $current ${_dim}(was $sha)${_off}"
else
  warn "kept $current — not fully merged into $base"
  printf '  %sif you are sure it is done (e.g. squash-merged): git branch -D %s%s\n' \
    "$_dim" "$current" "$_off" >&2
  exit 1
fi
