#!/usr/bin/env bash
#
# git-new — create a branch and switch to it.
#
# A thin wrapper around `git switch -c`, whose real point is the Tab
# completion: `git new <TAB>` cycles through short words already used in this
# repo's existing branch names (via zsh's _multi_parts), so composing a short
# name is a few Tab presses instead of typing a sentence. That completion
# works no matter who or what is driving the shell — it fires on the git
# command itself, not on any tool choosing to cooperate.
#
# Usage:
#   git new <name>            create <name> from the current branch, switch to it
#   git new -b <base> <name>  create <name> from <base> instead
#   git new -h                show this help
#
set -euo pipefail

# Resolve this script's real location (following symlinks — it's installed as
# one) to find lib/git-tools-common.sh, shared across the git-* tools:
# require_git_repo() here.
_src="${BASH_SOURCE[0]}"
while [ -h "$_src" ]; do
  _dir="$(cd -P "$(dirname "$_src")" && pwd)"
  _src="$(readlink "$_src")"
  [[ "$_src" != /* ]] && _src="$_dir/$_src"
done
source "$(cd -P "$(dirname "$_src")/.." && pwd)/lib/git-tools-common.sh"

usage() {
  cat <<'EOF'
git new — create a branch and switch to it (a thin wrapper around
`git switch -c`; the point is Tab-completing a short name — see
`git new` in the zsh completion, if you've enabled it).

Usage:
  git new <name>            create <name> from the current branch, switch to it
  git new -b <base> <name>  create <name> from <base> instead
  git new -h                show this help
EOF
}

base=""
name=""
while [ $# -gt 0 ]; do
  case "$1" in
    -h|--help) usage; exit 0 ;;
    -b|--base) shift; base="${1:-}" ;;
    -*) echo "git new: unknown option '$1' (try -h)" >&2; exit 2 ;;
    *) name="$1" ;;
  esac
  shift
done

[ -n "$name" ] || { echo "git new: give it a branch name (try -h)" >&2; exit 2; }

require_git_repo "git new"

if [ -n "$base" ]; then
  git switch -c "$name" "$base"
else
  git switch -c "$name"
fi
