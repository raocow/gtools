#!/usr/bin/env bash
#
# git-pr — list your open PRs, check one out, or merge one or more.
#
#   git pr                list your open PRs in this repo, as "<url> -- <title>"
#   git pr --no-title     just the URLs, one per line (easy to pipe)   [-nt]
#   git pr <n|branch>     check out that PR's branch, updated to the PR's latest
#   git pr merge <ids...> merge specific PR(s) (number, branch, URL, or a
#                         "NNN-MMM" range — all mixable)
#   git pr merge --all    merge every mergeable PR you authored   [-a]
#   git pr merge ... -x <ids...>   exclude PR(s) from either form   [--exclude]
#
# The checkout argument (and each merge argument) can be a PR number, a head
# branch name, or a PR URL — whatever `gh` can resolve to a pull request.
# Listing uses `gh pr list --author @me`. Checkout uses `gh pr checkout`, which
# creates the branch or fast-forwards an existing one to the PR's latest — so
# you're never on a stale copy. For a merged/closed PR whose head branch was
# deleted from origin, it falls back to `refs/pull/<n>/head`; if GitHub is
# unreachable, it falls back to a local branch (the stamped one for a number,
# or the named branch itself), switched to as-is (not updated).
#
# `git pr merge` touches shared remote state (it merges PRs on GitHub), but it
# acts by default — pass -n/--dry-run to preview first. There is no --force;
# anything blocked by branch protection (required reviews/checks) is always
# left alone, never bypassed.
#
# `git pr merge <ids...>` merges exactly the PRs you named, whoever authored
# them (same as naming a PR to `gh pr merge` — you're being explicit, so it's
# not scoped to your own). `git pr merge --all` has no ids and is a broad
# sweep, so THAT form only ever considers PRs YOU authored — merging someone
# else's PR isn't a sweep's call to make.
#
# An id may be a "NNN-MMM" range of PR numbers (either order), expanded into
# individual ids — a token only counts as a range if it's ENTIRELY digits, so
# a branch name like "task-42" passes through untouched. -x/--exclude takes
# one or more ids (same forms, plus ranges) to drop from either --all or an
# explicit id list — everything after -x is an exclude until the next flag.
# Duplicate/excluded ids that resolve to the same PR are each counted once.
#
# Merge order: it computes which of the targeted PRs touch overlapping files
# and processes the least-entangled ones first (fewest others sharing a
# changed file), so a PR that's easy to land doesn't sit behind one that needs
# a rebase. This is a static, one-time ordering from each PR's changed-file
# list — no LLM, no guessing, just a conflict-adjacency count.
#
# For each PR, in that order:
#   - mergeStateStatus CLEAN/UNSTABLE  → merge it directly (gh pr merge).
#   - BEHIND/DIRTY                     → rebase the branch onto its base in a
#                                         scratch worktree (never touches your
#                                         current branch/worktree) and push; if
#                                         the rebase itself hits conflicts,
#                                         abort it and skip — that needs a human.
#   - BLOCKED (required checks/reviews) → skip; never bypassed.
#   - draft                            → skip.
# Skipped PRs are listed at the end with why. Merging one PR can change the
# status of the ones after it (e.g. newly BEHIND) — each PR's status is
# re-checked right before it's handled, not just at the start.
#
# The merge method (merge/squash/rebase) defaults to the repo's own default
# (`gh repo view`'s viewerDefaultMergeMethod), or --method to override. Branches
# are never auto-deleted after merge — run `git sweep` afterward for that.
#
# (Named `git pr`, not `git switch`: git always prefers its built-in `switch`
# over a script, so a custom `git-switch` could never run. A branch literally
# named "merge" can't be checked out with `git pr merge` for the same reason
# `merge` is claimed as a subcommand — use `git pr merge merge` if you must.)
#
# Usage:
#   git pr                          list open PRs you authored ("<url> -- <title>")
#   git pr -nt                      list them as bare URLs (--no-title)
#   git pr <n|branch>                check out a PR by number, branch name, or URL
#   git pr merge <n|branch|range>... merge the given PR(s); "824-830" is a range
#   git pr merge --all              merge every mergeable PR you authored (-a)
#   git pr merge ... -x <ids...>    exclude PR(s) (--exclude; also takes ranges)
#   git pr merge ... -n             preview instead (--dry-run)
#   git pr merge ... --method squash|merge|rebase   override the merge method
#   git pr -h                       show this help
#
set -euo pipefail

# Colorized step output on a terminal (respects NO_COLOR). Mirrored across the
# git-* tools so they narrate their actions in one consistent format.
if [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
  _ok=$'\033[32m'; _warn=$'\033[33m'; _dim=$'\033[2m'; _off=$'\033[0m'
else
  _ok=''; _warn=''; _dim=''; _off=''
fi
step() { printf '%s✓%s %s\n' "$_ok" "$_off" "$1"; }
warn() { printf '%s!%s %s\n' "$_warn" "$_off" "$1" >&2; }

usage() {
  cat <<'EOF'
git pr — list your open PRs, check one out, or merge one or more.

  git pr                      list your open PRs in this repo, as "<url> -- <title>"
  git pr -nt                  list them as bare URLs (--no-title)
  git pr <n|branch>           check out that PR (by number, branch name, or
                              URL), updated to the PR's latest
  git pr merge <ids...>       merge the given PR(s) (number, branch, URL, or a
                              "824-830" range — all mixable), rebasing what
                              needs it, skipping what needs a human
  git pr merge --all          merge every mergeable PR YOU authored (-a)
  git pr merge ... -x <ids>   exclude PR(s) from either form (--exclude; also
                              takes ranges — everything after -x is excluded
                              until the next flag)
  git pr merge ... -n         preview instead: show the plan, change nothing
  git pr -h                   show this help

Uses the GitHub CLI (gh). Checkout falls back to refs/pull/<n>/head for deleted
branches, or (offline) to the local branch.

`git pr merge <ids>` merges exactly the PRs you named, whoever authored them.
`git pr merge --all` (no ids) is a broad sweep, so it only ever considers PRs
YOU authored — merging someone else's PR isn't a sweep's call to make. Branch
protection (required reviews/checks) is never bypassed either way. PRs are
merged in an order chosen to minimize conflicts — the least-entangled ones
(fewest others touching the same files) go first. A PR needing a rebase gets
one, in a scratch worktree that never touches your current branch; if the
rebase itself conflicts, that PR is skipped for you to resolve by hand.

  git pr merge 824-830 -x 825 827   merge #824-830 except #825 and #827

  git pr merge ... --method squash|merge|rebase   override the merge method
                                (default: the repo's own default merge method)
EOF
}

id=""
notitle=0
subcmd=""
all=0
dry=0
method=""
raw_targets=()   # positional args before -x: ids and/or "NNN-MMM" ranges
raw_excludes=()  # positional args after -x/--exclude
in_exclude=0     # once -x is seen, bare tokens go to raw_excludes until another flag

# `merge` is a subcommand, not a flag: `git pr merge <ids...>` / `--all`.
if [ "${1:-}" = "merge" ]; then subcmd="merge"; shift; fi

while [ $# -gt 0 ]; do
  case "$1" in
    -h|--help) usage; exit 0 ;;
    -nt|--no-title) notitle=1; in_exclude=0 ;;
    -a|--all) all=1; in_exclude=0 ;;
    -n|--dry-run) dry=1; in_exclude=0 ;;
    -x|--exclude)
      [ "$subcmd" = "merge" ] || {
        echo "git pr: --exclude only applies to 'git pr merge'" >&2; exit 2; }
      in_exclude=1 ;;
    --method) shift; method="${1:-}"; in_exclude=0 ;;
    -*) echo "git pr: unknown option '$1' (try -h)" >&2; exit 2 ;;
    *)
      if [ "$subcmd" != "merge" ]; then
        id="$1"
      elif [ "$in_exclude" = 1 ]; then
        raw_excludes+=("$1")
      else
        raw_targets+=("$1")
      fi
      ;;
  esac
  shift
done

if [ "$subcmd" != "merge" ]; then
  if [ "$all" = 1 ] || [ "$dry" = 1 ] || [ -n "$method" ] || [ "${#raw_excludes[@]}" -gt 0 ]; then
    echo "git pr: --all/--exclude/--dry-run/--method only apply to 'git pr merge'" >&2; exit 2
  fi
else
  if [ "$all" = 1 ] && [ "${#raw_targets[@]}" -gt 0 ]; then
    echo "git pr merge: can't combine --all with specific PRs" >&2; exit 2
  fi
  if [ "$all" = 0 ] && [ "${#raw_targets[@]}" -eq 0 ]; then
    echo "git pr merge: specify PR(s) to merge (number, branch, or URL — 'NNN-MMM' for a range), or --all for every one of your open PRs" >&2; exit 2
  fi
fi

# Expand "NNN-MMM" range tokens (PR numbers only) into individual ids. A token
# only counts as a range if it's ENTIRELY digits-hyphen-digits — a branch name
# like "task-42" has letters in it and passes through untouched. Applied to
# both the target list and the exclude list, so -x accepts ranges too.
expand_ranges() {  # expand_ranges <out-array-name> <in-token...>
  local out="$1"; shift
  local t lo hi tmp2
  for t in "$@"; do
    if printf '%s' "$t" | grep -qE '^[0-9]+-[0-9]+$'; then
      lo="${t%-*}"; hi="${t#*-}"
      [ "$lo" -gt "$hi" ] && { tmp2=$lo; lo=$hi; hi=$tmp2; }
      if [ $((hi - lo)) -gt 500 ]; then
        echo "git pr merge: range '$t' spans more than 500 PRs — that's probably a typo" >&2; exit 2
      fi
      while [ "$lo" -le "$hi" ]; do eval "$out+=(\"$lo\")"; lo=$((lo + 1)); done
    else
      eval "$out+=(\"\$t\")"
    fi
  done
}
merge_ids=(); expand_ranges merge_ids "${raw_targets[@]:-}"
exclude_ids=(); expand_ranges exclude_ids "${raw_excludes[@]:-}"

git rev-parse --is-inside-work-tree >/dev/null 2>&1 || {
  echo "git pr: not inside a git repository" >&2; exit 1; }
command -v gh >/dev/null 2>&1 || {
  echo "git pr: needs the GitHub CLI ('gh') — https://cli.github.com" >&2; exit 1; }

# ══════════════════════════════════════════════════════════════════════════
# git pr merge: merge specific PR(s), or --all mergeable PRs you authored.
# ══════════════════════════════════════════════════════════════════════════
if [ "$subcmd" = "merge" ]; then
  [ -n "$method" ] && method="$(printf '%s' "$method" | tr '[:upper:]' '[:lower:]')"
  case "$method" in
    ""|merge|squash|rebase) ;;
    *) echo "git pr merge: --method must be merge, squash, or rebase" >&2; exit 2 ;;
  esac

  tmp="$(mktemp -d)"
  trap 'rm -rf "$tmp"' EXIT
  files_dir="$tmp/files"
  mkdir -p "$files_dir"

  # Resolve the merge method: explicit --method, else the repo's own default
  # (gh repo view's viewerDefaultMergeMethod comes back UPPERCASE), else squash.
  if [ -z "$method" ]; then
    method="$(gh repo view --json viewerDefaultMergeMethod --jq '.viewerDefaultMergeMethod // ""' 2>/dev/null || true)"
    method="$(printf '%s' "$method" | tr '[:upper:]' '[:lower:]')"
    case "$method" in merge|squash|rebase) ;; *) method=squash ;; esac
  fi
  merge_flag="--$method"
  skipped=()

  # Resolve -x/--exclude ids to PR numbers up front (an exclude that doesn't
  # resolve to anything is just a no-op, not an error — it may already be
  # closed, which is what you wanted anyway).
  exclude_nums=""
  for xid in "${exclude_ids[@]}"; do
    xn="$(gh pr view "$xid" --json number --jq '.number' 2>/dev/null || true)"
    [ -n "$xn" ] && exclude_nums="$exclude_nums $xn"
  done

  # Gather the PR numbers to work on. --all is a broad sweep, so it's scoped
  # to PRs YOU authored — merging someone else's PR isn't a sweep's call to
  # make. Explicit ids are resolved (number/branch/URL, whoever authored them)
  # and deduped, since the same PR could be named twice (e.g. by number and by
  # branch). -x/--exclude removes matching PRs from either set.
  if [ "$all" = 1 ]; then
    nums=""
    for n in $(gh pr list --state open --author "@me" --limit 200 --json number --jq '.[].number' 2>/dev/null || true); do
      case " $exclude_nums " in *" $n "*) continue ;; esac
      nums="$nums $n"
    done
    if [ -z "$nums" ]; then
      echo "git pr merge: no open PRs authored by you in this repo (after --exclude)."
      exit 0
    fi
  else
    nums=""; seen_nums=""
    for mid in "${merge_ids[@]}"; do
      n="$(gh pr view "$mid" --json number,state --jq 'select(.state == "OPEN") | .number' 2>/dev/null || true)"
      if [ -z "$n" ]; then
        skipped+=("$mid -- couldn't resolve to an open PR")
        continue
      fi
      case " $seen_nums " in *" $n "*) continue ;; esac
      seen_nums="$seen_nums $n"
      case " $exclude_nums " in *" $n "*) skipped+=("#$n -- excluded"); continue ;; esac
      nums="$nums $n"
    done
    if [ -z "$nums" ]; then
      echo "git pr merge: none of the given PR(s) could be resolved (or all were excluded)."
      if [ "${#skipped[@]}" -gt 0 ]; then
        echo "Skipped:"; for s in "${skipped[@]}"; do echo "  $s"; done
      fi
      exit 0
    fi
  fi

  overlap_input="$tmp/overlap_input"; : > "$overlap_input"
  titles_file="$tmp/titles"; : > "$titles_file"

  cand=()
  for num in $nums; do
    info="$(gh pr view "$num" --json headRefName,baseRefName,isDraft,title \
      --jq '"\(.headRefName)\t\(.baseRefName)\t\(.isDraft)\t\(.title)"' 2>/dev/null)" || continue
    head="${info%%$'\t'*}"; rest="${info#*$'\t'}"
    base="${rest%%$'\t'*}"; rest="${rest#*$'\t'}"
    draft="${rest%%$'\t'*}"; title="${rest#*$'\t'}"
    printf '%s\t%s\t%s\n' "$num" "$head" "$base" >> "$tmp/meta"
    printf '%s\t%s\n' "$num" "$title" >> "$titles_file"
    if [ "$draft" = "true" ]; then
      skipped+=("#$num $title -- draft")
      continue
    fi
    gh pr view "$num" --json files --jq '.files[].path' 2>/dev/null | sort -u > "$files_dir/$num"
    cand+=("$num")
  done

  if [ "${#cand[@]}" -eq 0 ]; then
    echo "git pr merge: nothing to merge (all given PRs are drafts or unreadable)."
    if [ "${#skipped[@]}" -gt 0 ]; then
      echo "Skipped:"; for s in "${skipped[@]}"; do echo "  $s"; done
    fi
    exit 0
  fi

  # Order candidates by conflict-adjacency: for each PR, count how many other
  # candidates share at least one changed file; sort ascending (least-entangled
  # first), tie-break by PR number.
  #
  # Built as an inverted index (file -> the PRs that touch it) rather than a
  # pairwise scan over every PR pair: cost scales with the total number of
  # changed files, not the square of the PR count, so it stays fast even with
  # a large open-PR count (most files belong to exactly one PR and cost
  # nothing here; only files shared by multiple PRs do any work).
  cand_list="$tmp/cand_list"; printf '%s\n' "${cand[@]}" > "$cand_list"
  pairs="$tmp/pairs"; : > "$pairs"
  for num in "${cand[@]}"; do
    [ -s "$files_dir/$num" ] || continue
    sed "s/\$/\t$num/" "$files_dir/$num" >> "$pairs"
  done
  awk -F'\t' '
    FNR == NR { allnums[$1] = 1; next }
    { byfile[$1] = byfile[$1] " " $2 }
    END {
      for (f in byfile) {
        n = split(byfile[f], nums, " ")
        for (i = 1; i <= n; i++)
          for (j = 1; j <= n; j++) {
            if (i == j) continue
            key = nums[i] SUBSEP nums[j]
            if (!(key in seen)) { seen[key] = 1; ov[nums[i]]++ }
          }
      }
      for (p in allnums) printf "%d\t%s\n", (p in ov ? ov[p] : 0), p
    }
  ' "$cand_list" "$pairs" > "$overlap_input"
  order=()
  while IFS=$'\t' read -r _ovnum num; do order+=("$num"); done < <(sort -n -k1,1 -k2,2 "$overlap_input")

  title_of() { grep -m1 "^$1"$'\t' "$titles_file" | cut -f2-; }
  meta_of()  { grep -m1 "^$1"$'\t' "$tmp/meta"; }   # num\thead\tbase

  # Rebase a PR's branch onto its base in a scratch worktree, then push. Never
  # touches the current worktree/branch. Returns 0 on a clean rebase (and
  # leaves it pushed), 1 if the rebase itself needs manual resolution.
  rebase_and_push() {
    local head="$1" base="$2"
    if git worktree list --porcelain | grep -qF "branch refs/heads/$head"$'\n'; then
      return 2   # branch is checked out elsewhere — don't touch it
    fi
    local wt; wt="$tmp/wt-$head"
    git fetch --quiet origin "$head" "$base" 2>/dev/null || return 3
    git worktree add --quiet -B "$head" "$wt" "origin/$head" >/dev/null 2>&1 || return 3
    local ok=0
    if (cd "$wt" && git rebase --quiet "origin/$base" >/dev/null 2>&1); then
      if (cd "$wt" && git push --quiet --force-with-lease "origin" "HEAD:$head" >/dev/null 2>&1); then
        ok=0
      else
        ok=4   # rebased locally but couldn't push (protected ref, race, etc.)
      fi
    else
      (cd "$wt" && git rebase --abort >/dev/null 2>&1) || true
      ok=1
    fi
    git worktree remove --force "$wt" >/dev/null 2>&1 || true
    return "$ok"
  }

  merged=()
  plan=()   # dry-run: "#n title -- action" lines

  for num in "${order[@]}"; do
    title="$(title_of "$num")"
    meta="$(meta_of "$num")"; head="$(printf '%s' "$meta" | cut -f2)"; base="$(printf '%s' "$meta" | cut -f3)"

    status="$(gh pr view "$num" --json mergeStateStatus --jq '.mergeStateStatus' 2>/dev/null || echo UNKNOWN)"

    case "$status" in
      CLEAN|UNSTABLE)
        if [ "$dry" = 1 ]; then
          plan+=("#$num $title -- merge ($method)"); continue
        fi
        if err="$(gh pr merge "$num" "$merge_flag" 2>&1)"; then
          step "merged #$num ${_dim}($title)${_off}"
          merged+=("#$num $title")
        else
          warn "merge failed for #$num — ${err##*$'\n'}"
          skipped+=("#$num $title -- merge failed: ${err##*$'\n'}")
        fi
        ;;
      BEHIND|DIRTY)
        if [ "$dry" = 1 ]; then
          plan+=("#$num $title -- rebase onto $base, then merge"); continue
        fi
        rebase_and_push "$head" "$base"; rc=$?
        case "$rc" in
          0)
            if err="$(gh pr merge "$num" "$merge_flag" 2>&1)"; then
              step "rebased + merged #$num ${_dim}($title)${_off}"
              merged+=("#$num $title")
            else
              warn "rebased #$num but merge didn't go through yet — rerun 'git pr merge $num' to retry"
              skipped+=("#$num $title -- rebased and pushed; merge pending (rerun to retry)")
            fi
            ;;
          1) warn "skipping #$num — rebase needs manual conflict resolution"
             skipped+=("#$num $title -- rebase conflicts, needs manual resolution") ;;
          2) warn "skipping #$num — branch '$head' is checked out in a worktree"
             skipped+=("#$num $title -- branch checked out elsewhere") ;;
          *) warn "skipping #$num — couldn't fetch/rebase '$head'"
             skipped+=("#$num $title -- couldn't rebase (fetch/push failed)") ;;
        esac
        ;;
      BLOCKED)
        [ "$dry" = 1 ] && { plan+=("#$num $title -- skip: blocked (required checks/reviews)"); continue; }
        warn "skipping #$num — blocked by required checks or reviews"
        skipped+=("#$num $title -- blocked (required checks or reviews)")
        ;;
      *)
        if [ "$dry" = 1 ]; then
          plan+=("#$num $title -- attempt merge ($status)"); continue
        fi
        if err="$(gh pr merge "$num" "$merge_flag" 2>&1)"; then
          step "merged #$num ${_dim}($title)${_off}"
          merged+=("#$num $title")
        else
          warn "skipping #$num — $status: ${err##*$'\n'}"
          skipped+=("#$num $title -- $status: ${err##*$'\n'}")
        fi
        ;;
    esac
  done

  echo
  if [ "$dry" = 1 ]; then
    echo "Dry run — nothing was changed. Order (least-entangled first):"
    for p in "${plan[@]}"; do echo "  $p"; done
    [ "${#skipped[@]}" -gt 0 ] && { echo "Would skip:"; for s in "${skipped[@]}"; do echo "  $s"; done; }
    echo
    echo "Run without --dry-run to actually merge."
  else
    echo "Merged (${#merged[@]}):"
    for m in "${merged[@]}"; do echo "  $m"; done
    if [ "${#skipped[@]}" -gt 0 ]; then
      echo "Unmergeable / skipped (${#skipped[@]}):"
      for s in "${skipped[@]}"; do echo "  $s"; done
    fi
  fi
  exit 0
fi

# ══════════════════════════════════════════════════════════════════════════
# No argument: list your open PRs in this repo (titles by default).
# ══════════════════════════════════════════════════════════════════════════
if [ -z "$id" ]; then
  # Sorted ascending by PR number (gh's own default is newest-first).
  if [ "$notitle" = 1 ]; then
    gh pr list --author "@me" --state open --limit 100 --json number,url \
      --jq 'sort_by(.number) | .[].url'
  else
    gh pr list --author "@me" --state open --limit 100 --json number,url,title \
      --jq 'sort_by(.number) | .[] | "\(.url) -- \(.title)"'
  fi
  exit 0
fi

# ══════════════════════════════════════════════════════════════════════════
# An argument: check out that PR, updated to its latest.
# ══════════════════════════════════════════════════════════════════════════
# Resolve the PR from the id (number, branch, or URL) first — this gives us the
# PR number + head branch, and doubles as the online/offline signal.
info=$(gh pr view "$id" --json number,headRefName -q '"\(.number) \(.headRefName)"' 2>/dev/null || true)

if [ -n "$info" ]; then
  num=${info%% *}; branch=${info#* }
  # gh pr checkout creates the branch or fast-forwards an existing one, leaving
  # us on it.
  if gh pr checkout "$id" >/dev/null 2>&1; then
    git config "branch.$branch.gtools-pr" "$num" 2>/dev/null || true
    step "switched to $branch ${_dim}(PR #$num, up to date)${_off}"
    exit 0
  fi
  # Resolved the PR but checkout failed — usually a merged/closed PR whose head
  # branch was deleted from origin. Use the ref GitHub keeps around.
  warn "head branch gone from origin — using refs/pull/$num/head"
  if git fetch --quiet origin "refs/pull/$num/head:$branch" 2>/dev/null; then
    git switch --quiet "$branch"
    git config "branch.$branch.gtools-pr" "$num" 2>/dev/null || true
    step "switched to $branch ${_dim}(PR #$num)${_off}"
  else
    echo "git pr: couldn't check out PR #$num — '$branch' may have diverged; resolve by hand" >&2
    exit 1
  fi
  exit 0
fi

# gh couldn't resolve $id (GitHub unreachable, or no PR for it). Fall back to a
# local branch: the stamped one for a number, or the named branch itself.
if printf '%s' "$id" | grep -qE '^[0-9]+$'; then
  stamped=$(git config --get-regexp '^branch\..*\.gtools-pr$' 2>/dev/null \
    | awk -v n="$id" '$2 == n { print $1; exit }' \
    | sed -E 's/^branch\.(.*)\.gtools-pr$/\1/') || true
  if [ -n "${stamped:-}" ] && git show-ref --verify --quiet "refs/heads/$stamped"; then
    git switch --quiet "$stamped"
    warn "couldn't reach GitHub — on existing $stamped (not updated)"
    exit 0
  fi
  echo "git pr: couldn't find PR #$id (offline, or not a PR in this repo)" >&2; exit 1
elif git show-ref --verify --quiet "refs/heads/$id"; then
  git switch --quiet "$id"
  warn "couldn't resolve a PR for '$id' via gh — switched to local branch as-is"
  exit 0
else
  echo "git pr: couldn't resolve '$id' to a PR or local branch" >&2; exit 1
fi
