#!/usr/bin/env bash
#
# git-slug — turn a description into a short, hyphenated branch-name slug.
#
# Mechanical, not clever: lowercase, drop punctuation, drop filler words, keep
# the first few significant words, hard-cap the length. The point isn't a
# perfect name — it's a HARD CEILING, so a verbose description can't produce
# a verbose branch name. Pipe it straight into a checkout:
#
#   git switch -c "$(git slug fix the markdown deep nesting crash)"
#
# Usage:
#   git slug <word>...        slug from the given words (max 3 words, 24 chars)
#   git slug -n 4 <word>...    keep up to 4 significant words instead of 3
#   git slug -l 30 <word>...   cap at 30 characters instead of 24
#   git slug -t ID <word>...   prefix "id-" (e.g. a ticket number)   [--ticket]
#   git slug -h                show this help
#
set -euo pipefail

usage() {
  cat <<'EOF'
git slug — turn a description into a short, hyphenated branch-name slug.

Mechanical, not clever: lowercase, drop punctuation and filler words, keep the
first few significant words, hard-cap the length. Pipe straight into a
checkout:

  git switch -c "$(git slug fix the markdown deep nesting crash)"

Usage:
  git slug <word>...       slug from the given words (max 3 words, 24 chars)
  git slug -n 4 <word>...   keep up to 4 significant words instead of 3
  git slug -l 30 <word>...  cap at 30 characters instead of 24
  git slug -t ID <word>...  prefix "id-" (e.g. a ticket number)   [--ticket]
  git slug -h               show this help
EOF
}

nwords=3
maxlen=24
ticket=""
words=()
while [ $# -gt 0 ]; do
  case "$1" in
    -h|--help) usage; exit 0 ;;
    -n) shift; nwords="${1:-3}" ;;
    -l) shift; maxlen="${1:-24}" ;;
    -t|--ticket) shift; ticket="${1:-}" ;;
    -*) echo "git slug: unknown option '$1' (try -h)" >&2; exit 2 ;;
    *) words+=("$1") ;;
  esac
  shift
done

[ "${#words[@]}" -gt 0 ] || { echo "git slug: give it something to slug (try -h)" >&2; exit 2; }

# Stopwords dropped before counting toward -n, so they don't crowd out the
# words that actually carry meaning.
stop=" a an the to for of and or with on in into this that is are your our my "

text="$(printf '%s ' "${words[@]}" | tr '[:upper:]' '[:lower:]')"
# Punctuation -> spaces, collapse whitespace.
text="$(printf '%s' "$text" | tr -c '[:alnum:] ' ' ' | tr -s ' ')"

kept=()
for w in $text; do
  # Skip stopwords and single-character fragments (near-always punctuation
  # debris, e.g. the "s" left behind by "Markdown's").
  [ "${#w}" -gt 1 ] || continue
  case "$stop" in *" $w "*) continue ;; esac
  kept+=("$w")
  [ "${#kept[@]}" -ge "$nwords" ] && break
done
[ "${#kept[@]}" -gt 0 ] || kept=("${words[@]:0:1}")  # all-stopwords edge case

slug="$(printf '%s-' "${kept[@]}")"; slug="${slug%-}"
[ -n "$ticket" ] && slug="$(printf '%s' "$ticket" | tr '[:upper:]' '[:lower:]')-$slug"

# Hard length cap — cut at a hyphen boundary where possible rather than
# mid-word, then strip any trailing hyphen left by the cut.
if [ "${#slug}" -gt "$maxlen" ]; then
  cut="${slug:0:$maxlen}"
  if printf '%s' "$cut" | grep -q -- '-'; then
    trimmed="${cut%-*}"
    [ -n "$trimmed" ] && cut="$trimmed"
  fi
  slug="${cut%-}"
fi

printf '%s\n' "$slug"
