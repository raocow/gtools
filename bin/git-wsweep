#!/usr/bin/env bash
#
# git-wsweep — remove worktrees whose HEAD is already merged into the base.
#
# The worktree analogue of `git sweep`. Where `git sweep` deletes merged
# *branches*, `git wsweep` removes merged *worktrees* — the linked working
# directories — and KEEPS the branches. So you can drop throwaway per-task
# checkouts and still `git switch` / `git pr` the branch later from your main
# worktree. (Removing a worktree never deletes its branch; run `git sweep`
# afterwards if you also want the merged branches gone.)
#
# Like git-sweep, it fetches first and judges "merged" against the base's REMOTE
# tip (origin/<base>), so it works without pulling the base and from any
# worktree. Safe by default: a worktree is removed only when its HEAD is already
# an ancestor of the base's remote tip (verified with `git merge-base
# --is-ancestor`), so no unmerged work is lost. The main worktree and the
# worktree you're currently in are never touched.
#
# --force widens the net to EVERY other worktree regardless of merge status and
# removes with `git worktree remove --force`, so it also drops worktrees that
# have uncommitted changes. That DISCARDS the uncommitted changes in those trees
# (the branches themselves survive). Preview with -n first.
#
# Usage:
#   git wsweep           remove worktrees whose HEAD is merged into the base (safe)
#   git wsweep -f        force: remove every worktree except main + current
#   git wsweep -n        dry run — list what would be removed, change nothing
#   git wsweep -b NAME   base branch to compare against (default: origin's default)
#   git wsweep -h        show this help
#
set -euo pipefail

# Resolve this script's real location (following symlinks — it's installed as
# one) to find lib/gitplus-common.sh, shared across the git-* tools: the
# color/step/warn helpers and resolve_base().
_src="${BASH_SOURCE[0]}"
while [ -h "$_src" ]; do
  _dir="$(cd -P "$(dirname "$_src")" && pwd)"
  _src="$(readlink "$_src")"
  [[ "$_src" != /* ]] && _src="$_dir/$_src"
done
source "$(cd -P "$(dirname "$_src")/.." && pwd)/lib/gitplus-common.sh"

usage() {
  cat <<'EOF'
git wsweep — remove worktrees whose HEAD is already merged into the base branch.

The worktree analogue of `git sweep`: it removes merged worktrees (the working
directories) but KEEPS the branches, so you can drop throwaway per-task
checkouts and still switch to the branch later from your main worktree.

Safe by default: a worktree is removed only when its HEAD is already an ancestor
of the base's remote tip (verified with merge-base), judged against origin/<base>
after a fetch — so it works without pulling the base and never drops unmerged
work. The main worktree and the one you're currently in are never touched.

--force removes EVERY other worktree regardless of merge status, with
`git worktree remove --force` — so it also drops worktrees with uncommitted
changes (discarding those changes; the branches survive). Run with -n first.

Usage:
  git wsweep         remove worktrees whose HEAD is merged into the base (safe)
  git wsweep -f      force: remove every worktree except main + current
  git wsweep -n      dry run — list what would be removed, change nothing
  git wsweep -b NAME base branch to compare against (default: origin's default)
  git wsweep -h      show this help

  -f and -n combine: `git wsweep -f -n` previews the force sweep.
EOF
}

dry=0
force=0
base=""
while [ $# -gt 0 ]; do
  case "$1" in
    -n|--dry-run) dry=1 ;;
    -f|--force) force=1 ;;
    -b|--base) shift; base="${1:-}" ;;
    -h|--help) usage; exit 0 ;;
    *) echo "git wsweep: unknown option '$1' (try -h)" >&2; exit 2 ;;
  esac
  shift
done

require_git_repo "git wsweep"

# Refresh remote-tracking refs first (best effort; ignore offline failures) so
# "merged" is judged against origin's current tip — mirrors git-sweep, so a
# worktree on a branch merged upstream is swept even if local <base> is stale.
git fetch --prune --quiet 2>/dev/null || true

# Choose a base branch NAME if none given: origin's default, else main/master,
# else the current branch. (Shared with git-sweep.)
base="$(resolve_base "$base")"

if git show-ref --verify --quiet "refs/remotes/origin/$base"; then
  mergeref="origin/$base"
elif git show-ref --verify --quiet "refs/heads/$base"; then
  mergeref="$base"
else
  echo "git wsweep: base '$base' not found locally or on origin" >&2; exit 1
fi

# The main worktree is always listed first by `git worktree list --porcelain`;
# never remove it. Never remove the worktree we're currently in either.
main_wt=$(git worktree list --porcelain | sed -n 's/^worktree //p' | head -1)
cur_wt=$(git rev-parse --show-toplevel)

# Walk the porcelain records (blank-line separated). Judge each worktree by its
# HEAD commit's reachability from $mergeref, which covers both branch-backed and
# detached worktrees (a merged detached HEAD is still safe to drop).
targets=()   # worktree paths to remove
labels=()    # human label per target
skipped=""   # unmerged worktrees skipped in safe mode
path=""; branch=""; head=""

consider() {
  [ -z "$path" ] && return
  # Never the main or the current worktree.
  if [ "$path" = "$main_wt" ] || [ "$path" = "$cur_wt" ]; then return; fi
  local label
  if [ -n "$branch" ]; then label="$path [$branch]"; else label="$path [detached]"; fi
  if [ "$force" = 1 ]; then
    targets+=("$path"); labels+=("$label")
  elif [ -n "$head" ] && git merge-base --is-ancestor "$head" "$mergeref" 2>/dev/null; then
    targets+=("$path"); labels+=("$label")
  else
    skipped="${skipped}  ${label} (not merged into ${mergeref})"$'\n'
  fi
}

while IFS= read -r line; do
  case "$line" in
    "worktree "*) consider; path="${line#worktree }"; branch=""; head="" ;;
    "HEAD "*)     head="${line#HEAD }" ;;
    "branch "*)   branch="${line#branch refs/heads/}" ;;
    "detached")   branch="" ;;
  esac
done < <(git worktree list --porcelain)
consider

if [ ${#targets[@]} -eq 0 ]; then
  if [ "$force" = 1 ]; then
    echo "git wsweep: no other worktrees to remove."
  else
    echo "git wsweep: no merged worktrees to remove."
  fi
  [ -n "$skipped" ] && { echo "Skipped (unmerged; use -f to force):"; printf '%s' "$skipped"; }
  exit 0
fi

if [ "$dry" = 1 ]; then
  if [ "$force" = 1 ]; then
    echo "Would remove (every worktree except main + current):"
  else
    echo "Would remove (HEAD merged into '$mergeref'; branches kept):"
  fi
  for l in "${labels[@]}"; do echo "  $l"; done
  [ -n "$skipped" ] && { echo "Skipped (unmerged):"; printf '%s' "$skipped"; }
  exit 0
fi

# Note: build the command per-branch rather than expanding a possibly-empty
# flag array — `"${arr[@]}"` on an empty array trips `set -u` on bash 3.2 (macOS).
for i in "${!targets[@]}"; do
  if [ "$force" = 1 ]; then
    ok=1; git worktree remove --force "${targets[$i]}" 2>/dev/null || ok=0
  else
    ok=1; git worktree remove "${targets[$i]}" 2>/dev/null || ok=0
  fi
  if [ "$ok" = 1 ]; then
    step "removed ${labels[$i]}"
  else
    warn "couldn't remove ${targets[$i]} — uncommitted changes? use -f"
  fi
done
git worktree prune
[ -n "$skipped" ] && { echo "Skipped (unmerged; use -f to force):"; printf '%s' "$skipped"; }
