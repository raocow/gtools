#!/usr/bin/env bash
#
# git-sync — rebase the current branch onto the latest base, then push it.
#
# Does: git fetch  →  git rebase origin/<base>  →  git push --force-with-lease
# (force-with-lease because a rebase rewrites history; it still refuses to
# clobber remote commits you haven't pulled).
#
# On the base branch itself it acts like a safe pull instead: git fetch → git
# rebase origin/<base> (fast-forwards when you're only behind), and never pushes.
#
# With --all, sweeps EVERY local branch in one pass: prunes the ones already
# merged into the base, rebases + pushes the rest, and cleanly skips any that
# hit rebase conflicts (aborting them untouched) so you can resolve those by
# hand. Squash-merged branches aren't detected as merged, so they get rebased
# rather than pruned — delete those yourself (or `git sweep -f`).
#
# Usage:
#   git sync            rebase the current branch onto origin's default, push
#   git sync --all      prune merged branches + rebase/push all the rest
#   git sync -b NAME    use origin/NAME as the base instead
#   git sync -n         dry run — print what it would do, change nothing
#   git sync -h         show this help
#
set -euo pipefail

# Colorized step output on a terminal (respects NO_COLOR). Mirrored across the
# git-* tools so they narrate their actions in one consistent format.
if [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
  _ok=$'\033[32m'; _warn=$'\033[33m'; _dim=$'\033[2m'; _off=$'\033[0m'
else
  _ok=''; _warn=''; _dim=''; _off=''
fi
step() { printf '%s✓%s %s\n' "$_ok" "$_off" "$1"; }
warn() { printf '%s!%s %s\n' "$_warn" "$_off" "$1" >&2; }

usage() {
  cat <<'EOF'
git sync — rebase onto the latest base and push. `--all` does the whole repo.

Single branch (default): git fetch → git rebase origin/<base> → git push
  --force-with-lease.

--all: fetch, fast-forward local <base>, then for every other local branch —
  delete it if it's already merged into origin/<base>, else rebase it onto
  origin/<base> and push. Branches that hit rebase conflicts are aborted
  untouched and listed for you to sync by hand. Never-pushed branches are
  rebased locally but not pushed. Squash-merged branches look unmerged, so they
  get rebased, not pruned.

On the base branch: acts as a safe pull — git fetch → git rebase origin/<base>
  (fast-forwards when only behind), no push.

Usage:
  git sync            rebase the current branch onto origin's default, then push
                      (on the base branch: pull it — fetch + rebase, no push)
  git sync --all      prune merged branches + rebase/push all the rest (-a)
  git sync -b NAME    use origin/NAME as the base instead
  git sync -n         dry run — print what it would do, change nothing
  git sync -h         show this help
EOF
}

dry=0
all=0
base=""
while [ $# -gt 0 ]; do
  case "$1" in
    -n|--dry-run) dry=1 ;;
    -a|--all) all=1 ;;
    -b|--base) shift; base="${1:-}" ;;
    -h|--help) usage; exit 0 ;;
    *) echo "git sync: unknown option '$1' (try -h)" >&2; exit 2 ;;
  esac
  shift
done

git rev-parse --is-inside-work-tree >/dev/null 2>&1 || {
  echo "git sync: not inside a git repository" >&2; exit 1; }

current=$(git rev-parse --abbrev-ref HEAD)
[ "$current" != "HEAD" ] || {
  echo "git sync: detached HEAD — check out a branch first" >&2; exit 1; }

# Base = origin's default branch unless told otherwise.
if [ -z "$base" ]; then
  base=$(git symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null \
    | sed 's#^origin/##' || true)
  [ -n "$base" ] || base=main
fi

# A rebase needs a clean tree; bail early with a clear message (both modes).
if ! git diff --quiet || ! git diff --cached --quiet; then
  echo "git sync: you have uncommitted changes — commit or stash them first" >&2
  exit 1
fi

# --------------------------------------------------------------------------
# --all: sweep every local branch (prune merged, rebase/push the rest).
# --------------------------------------------------------------------------

# Print a labelled list, but only if the list is non-empty (bash 3.2 safe).
_report() {
  label="$1"; shift
  [ "$#" -eq 0 ] && return 0
  printf '%s%s:%s\n' "$_dim" "$label" "$_off"
  for b in "$@"; do echo "  $b"; done
}

sync_all() {
  start=$current

  if [ "$dry" = 1 ]; then
    git fetch origin --prune
    echo
    echo "Against 'origin/$base', would:"
    while IFS= read -r b; do
      [ "$b" = "$base" ] && continue
      if git merge-base --is-ancestor "$b" "origin/$base" 2>/dev/null; then
        echo "  prune (merged):    $b"
      else
        echo "  rebase + push:     $b"
      fi
    done < <(git for-each-ref --format='%(refname:short)' refs/heads/)
    return 0
  fi

  git fetch origin --prune

  # Fast-forward local base to the remote tip so a merged-check against it (and
  # the eventual `branch -d`) sees current state. Best effort — skip if diverged.
  if [ "$current" != "$base" ]; then
    git checkout --quiet "$base"
  fi
  git merge --ff-only "origin/$base" >/dev/null 2>&1 \
    || echo "note: local '$base' didn't fast-forward (diverged?) — continuing." >&2

  synced=(); pushedless=(); pruned=(); conflicts=(); skipped=()
  while IFS= read -r b; do
    [ "$b" = "$base" ] && continue
    if git merge-base --is-ancestor "$b" "origin/$base" 2>/dev/null; then
      if git branch -d "$b" >/dev/null 2>&1; then pruned+=("$b"); else skipped+=("$b"); fi
      continue
    fi
    git checkout --quiet "$b" || { skipped+=("$b"); continue; }
    if git rebase "origin/$base" >/dev/null 2>&1; then
      # Push if the branch has an upstream OR already exists on origin (pushed
      # once without -u). A purely local branch is left alone — don't create a
      # remote for it.
      if git rev-parse --abbrev-ref --symbolic-full-name '@{u}' >/dev/null 2>&1 \
        || git show-ref --verify --quiet "refs/remotes/origin/$b"; then
        if git push --force-with-lease --force-if-includes origin "$b" >/dev/null 2>&1
        then
          synced+=("$b")
        else
          skipped+=("$b")  # push refused (protected / lost the lease) — leave it
        fi
      else
        pushedless+=("$b")  # rebased, but never pushed → don't create a remote
      fi
    else
      git rebase --abort >/dev/null 2>&1 || true
      conflicts+=("$b")
    fi
  done < <(git for-each-ref --format='%(refname:short)' refs/heads/)

  # Return to where we started (or the base if that branch got pruned).
  if git show-ref --verify --quiet "refs/heads/$start"; then
    git checkout --quiet "$start"
  else
    git checkout --quiet "$base"
  fi

  echo
  _report "Synced (rebased + pushed)"   ${synced[@]+"${synced[@]}"}
  _report "Rebased (local only)"        ${pushedless[@]+"${pushedless[@]}"}
  _report "Pruned (merged)"             ${pruned[@]+"${pruned[@]}"}
  _report "Conflicts — sync by hand"    ${conflicts[@]+"${conflicts[@]}"}
  _report "Skipped"                     ${skipped[@]+"${skipped[@]}"}
  if [ "${#conflicts[@]}" -gt 0 ]; then
    echo
    warn "for each conflict: git checkout <branch> && git sync"
  fi
}

if [ "$all" = 1 ]; then
  sync_all
  exit 0
fi

# --------------------------------------------------------------------------
# Single-branch (default).
# --------------------------------------------------------------------------

# On the base branch itself, `git sync` acts like a safe pull: fetch and bring
# local <base> in line with origin/<base>, replaying any local commits on top
# (rebase → fast-forward when you're only behind). It never pushes — you don't
# force-push the base, and updating it locally is the whole point here.
if [ "$current" = "$base" ]; then
  git show-ref --verify --quiet "refs/remotes/origin/$base" || {
    echo "git sync: no 'origin/$base' to sync from" >&2; exit 1; }
  if [ "$dry" = 1 ]; then
    echo "Would run, on base '$base':"
    echo "  git fetch origin --prune"
    echo "  git rebase origin/$base   (fast-forwards if you're only behind)"
    echo "  (no push — syncing the base only updates it locally)"
    exit 0
  fi
  git fetch --quiet origin --prune
  if [ "$(git rev-parse HEAD)" = "$(git rev-parse "origin/$base")" ]; then
    step "$base already up to date with origin/$base"
    exit 0
  fi
  if ! git rebase "origin/$base" >/dev/null 2>&1; then
    warn "rebase hit conflicts pulling $base — resolve (git status), then: git rebase --continue (or --abort)"
    exit 1
  fi
  step "pulled $base ${_dim}(rebased onto origin/$base, local only — not pushed)${_off}"
  exit 0
fi

if [ "$dry" = 1 ]; then
  echo "Would run, on branch '$current':"
  echo "  git fetch origin --prune"
  echo "  git rebase origin/$base"
  echo "  git push --force-with-lease --force-if-includes"
  exit 0
fi

git fetch --quiet origin --prune

if ! git rebase "origin/$base" >/dev/null 2>&1; then
  warn "rebase hit conflicts — resolve (git status), then: git rebase --continue (or --abort), then git push --force-with-lease"
  exit 1
fi

# Force-with-lease only makes sense once the branch has an upstream; the first
# push just sets one.
if git rev-parse --abbrev-ref --symbolic-full-name '@{u}' >/dev/null 2>&1; then
  if git push --force-with-lease --force-if-includes >/dev/null 2>&1; then
    step "synced $current ${_dim}(rebased onto origin/$base, pushed)${_off}"
  else
    warn "rebased, but push was refused (protected branch or lost lease) — push by hand"; exit 1
  fi
else
  if git push -u origin "$current" >/dev/null 2>&1; then
    step "synced $current ${_dim}(rebased onto origin/$base, pushed new branch)${_off}"
  else
    warn "rebased, but push failed — push by hand"; exit 1
  fi
fi
