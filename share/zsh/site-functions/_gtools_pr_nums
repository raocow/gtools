#autoload
#
# Open PR numbers, each shown with its title — for `git pr`, which is about
# picking a PR. Just the numbers, no branch list: dumping every local/remote
# branch here would bury the handful of PRs you actually want in noise (you
# can still type a branch name; it just isn't offered). compadd must run in
# THIS shell, so candidates are gathered into arrays first, never piped into
# a subshell.
local -a prs pr_nums pr_descs
prs=(${(f)"$(_gtools_open_prs)"})
local p num rest branch title
for p in $prs; do
  num="${p%%$'\t'*}"; rest="${p#*$'\t'}"
  branch="${rest%%$'\t'*}"; title="${rest#*$'\t'}"
  pr_nums+=("$num")
  pr_descs+=("$num  $title")
done
(( $#pr_nums )) && compadd -X 'open PRs' -d pr_descs -a pr_nums
