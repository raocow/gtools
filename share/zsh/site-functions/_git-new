#autoload
#
# Completion for `git new` — the actual fix for chronically-verbose branch
# names: Tab cycles through short words already used in this repo's existing
# branch names (via _multi_parts, zsh's standard "compose from
# hyphen-separated segments" completer), instead of typing a sentence.
# Nothing generated or guessed — same principle as `cd` completing real
# directories, just this repo's own naming precedent instead of a filesystem.
if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  _message -r 'not inside a git repository'; return
fi
case ${words[CURRENT-1]} in
  -b|--base) _gitplus_branches; return ;;
esac
if [[ ${words[CURRENT]} == -* ]]; then
  _alternative 'flags:Flag:(-b --base -h --help)'
  return
fi
local -a tokens
tokens=(${(f)"$(_gitplus_branch_tokens)"})
# The first lone `-` is an end-of-options terminator (zparseopts consumes
# it); the second is the actual separator. Without the terminator, the
# separator itself gets swallowed as an option, the array name is taken as
# the separator, and the function silently completes nothing — zsh then
# falls through to plain file completion.
_multi_parts - - tokens
